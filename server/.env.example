# LLM API Configuration
# Get your API key from https://aistudio.google.com/
LLM_API_KEY=your_gemini_api_key_here

# LLM Provider (options: gemini, openai, anthropic, cohere, etc.)
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_API_VERSION=v1
# Optional override, defaults to Google public endpoint
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Save raw LLM responses to OS temp directory (for manual verification)
LLM_SAVE_RAW_RESPONSES=true

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=True

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5174,https://palette-ai-delta.vercel.app

# Frontend Configuration (used by Vite)
VITE_API_URL=http://localhost:8000
